OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
EXA_API_KEY=...
PAGE_TEXT_LIMIT=12000
# Прокси для исходящих запросов (EXA/LLM). Пусто = напрямую. Напр. http://127.0.0.1:8118
PROXY_URL=
# Провайдер озвучки (инструмент text_to_speech): edge (бесплатно) | elevenlabs
TTS_PROVIDER=edge
# Голос edge-tts (когда TTS_PROVIDER=edge)
TTS_VOICE=ru-RU-SvetlanaNeural
# ElevenLabs (когда TTS_PROVIDER=elevenlabs): ключ обязателен, иначе фолбэк на edge
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa
ELEVENLABS_MODEL=eleven_multilingual_v2
# Langfuse (наблюдаемость, опционально): ключи проекта с cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Регион: https://cloud.langfuse.com (EU) или https://us.cloud.langfuse.com (US)
LANGFUSE_HOST=https://cloud.langfuse.com
